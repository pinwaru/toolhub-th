<!DOCTYPE html>
<html lang="th">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Scientific Calculator | ToolHub TH</title>

<meta name="description" content="เครื่องคิดเลขวิทยาศาสตร์ออนไลน์ฟรี รองรับ sin cos tan log ln √ x² xʸ π และอื่น ๆ">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="../css/style.css">

<style>

.calculator{
    max-width:700px;
    margin:50px auto;
    background:#fff;
    padding:30px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.1);
}

.calculator h1{
    text-align:center;
    margin-bottom:25px;
    color:#2563eb;
}

#display{
    width:100%;
    box-sizing:border-box;
    height:70px;
    font-size:32px;
    text-align:right;
    padding:15px;
    border:2px solid #ddd;
    border-radius:12px;
    margin-bottom:25px;
    background:#f8fafc;
}

.buttons{
    display:grid;
    grid-template-columns:repeat(5,1fr);
    gap:12px;
}

.buttons button{
    height:60px;
    font-size:20px;
    border:none;
    border-radius:12px;
    cursor:pointer;
    background:#2563eb;
    color:white;
    transition:.2s;
    font-family:'Kanit',sans-serif;
}

.buttons button:hover{
    background:#1d4ed8;
    transform:translateY(-2px);
}

.buttons button:active{
    transform:scale(.96);
}

@media(max-width:768px){

.calculator{
    margin:20px;
    padding:20px;
}

#display{
    font-size:26px;
}

.buttons button{
    height:55px;
    font-size:18px;
}

}

</style>

</head>

<body>

<nav class="navbar">

<div class="logo">

<img src="../images/logo.png" alt="ToolHub TH">

<span>ToolHub TH</span>

</div>

<div class="menu">

<a href="../index.html">หน้าแรก</a>
<a href="../blog.html">บทความ</a>
